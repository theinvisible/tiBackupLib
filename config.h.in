// NOTE: this file is generated from config.h.in by CMake. The single source of
// truth for the version is the project(... VERSION ...) line in CMakeLists.txt;
// do not edit the generated config.h directly.

#ifndef CONFIG_H
#define CONFIG_H

#include <QDataStream>
#include <QDir>
#include <QFileInfo>
#include <QLatin1String>
#include <QString>

namespace tibackup_config
{
    [[maybe_unused]] static constexpr QLatin1String version{"@PROJECT_VERSION@"};
    [[maybe_unused]] static constexpr QLatin1String file_main{"/etc/tibackup/main.conf"};
    [[maybe_unused]] static constexpr QLatin1String mount_root{"/mnt"};
    [[maybe_unused]] static constexpr QLatin1String initd_default{"/etc/init.d/tibackup"};
    [[maybe_unused]] static constexpr QLatin1String api_sock_name{"tibackup"};
    [[maybe_unused]] static constexpr QLatin1String systemd_name{"tibackupd"};
    [[maybe_unused]] static constexpr QDataStream::Version ipc_version = QDataStream::Qt_5_7;
    [[maybe_unused]] static constexpr QLatin1String backup_detail_folder{"backup_detail"};

    // Default system user that pre/post-backup scripts are executed as. The daemon
    // runs as root but drops to this unprivileged user before running a job script,
    // so a web-authored script is not root-equivalent (root only via explicit sudo).
    // Overridable via the main.conf key scripts/run_user (root-only; never exposed
    // through the web API). Created by the package postinst.
    [[maybe_unused]] static constexpr QLatin1String script_run_user{"tibackup"};

    [[maybe_unused]] static constexpr QLatin1String var_partbackup_dir{"%MNTBACKUPDIR%"};

    // Default From/sender for notification mails. Overridable via the main.conf
    // key smtp/from (and the web Settings UI); kept as the historical default so
    // existing installs keep the same sender after upgrade.
    [[maybe_unused]] static constexpr QLatin1String mail_from_default{"tiBackup Backupsystem <tibackup@iteas.at>"};

    // Resolve the main config file path. Honours the TIBACKUP_CONF env override
    // (dev/CI only): when set, the whole config tree - main.conf plus the
    // jobs/pbservers/logs/scripts dirs derived from it - is redirected there, so
    // the daemon can run without touching the root-owned /etc/tibackup. Mirrors
    // the TIBACKUP_WEB_DOCROOT / TIBACKUP_WEB_PORT overrides in the web server.
    // Falls back to the compiled-in file_main when the env var is unset/empty.
    [[maybe_unused]] inline QString mainConfigFile()
    {
        const QByteArray ov = qgetenv("TIBACKUP_CONF");
        if(!ov.isEmpty())
            return QString::fromLocal8Bit(ov);
        return QString(file_main);
    }

    // Default directory for tiBackup's logs (main tibackup.log + backup_detail +
    // per-job rsync logs). FHS-correct /var/log/tibackup for real installs; but
    // when the config tree is redirected via TIBACKUP_CONF (dev/CI) the logs stay
    // INSIDE that tree so test runs remain isolated and need no root-owned
    // /var/log. Mirrors the redirection logic in mainConfigFile().
    [[maybe_unused]] inline QString logsDir()
    {
        const QByteArray ov = qgetenv("TIBACKUP_CONF");
        if(!ov.isEmpty())
        {
            const QFileInfo finfo(QString::fromLocal8Bit(ov));
            return QString("%1/logs").arg(finfo.absoluteDir().absolutePath());
        }
        return QStringLiteral("/var/log/tibackup");
    }

    // Sidecar holding the scheduler's per-job last-run timestamps. Kept OUT of the
    // job .conf on purpose: tiConfBackupJobs::saveBackupJob rewrites that file on
    // every edit, which would wipe the state. Lives next to main.conf (root-only)
    // and honours the same TIBACKUP_CONF redirection via mainConfigFile().
    [[maybe_unused]] inline QString schedulerStateFile()
    {
        const QFileInfo finfo(mainConfigFile());
        return QString("%1/scheduler_state.conf").arg(finfo.absoluteDir().absolutePath());
    }
}

#endif // CONFIG_H
