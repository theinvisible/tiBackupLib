#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	mkdir -p debian/tibackuplib-dev/usr/include/tibackuplib/obj
	mkdir -p debian/tibackuplib-dev/usr/include/tibackuplib/workers
	mkdir -p debian/tibackuplib-dev/usr/lib/cmake/tiBackupLib
	cp -a ../*.h debian/tibackuplib-dev/usr/include/tibackuplib/.
	# config.h is generated by CMake from config.h.in; this package has no CMake
	# build step, so reproduce it here by substituting the version that is kept
	# centrally in ../CMakeLists.txt (project(tiBackupLib VERSION X)).
	ver=$$(sed -n 's/^project(tiBackupLib VERSION \([0-9][0-9.]*\).*/\1/p' ../CMakeLists.txt); \
	sed "s/@PROJECT_VERSION@/$$ver/g" ../config.h.in > debian/tibackuplib-dev/usr/include/tibackuplib/config.h
	cp -a ../obj/*.h debian/tibackuplib-dev/usr/include/tibackuplib/obj/.
	cp -a ../workers/*.h debian/tibackuplib-dev/usr/include/tibackuplib/workers/.
	cp -a ../cmake/tiBackupLibConfig.cmake debian/tibackuplib-dev/usr/lib/cmake/tiBackupLib/.

override_dh_builddeb:
	dh_builddeb -- -Zxz
